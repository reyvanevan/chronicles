<!-- Music / Audio -->
<div class="fixed bottom-4 right-4 md:bottom-6 md:right-6 z-40">
    <div id="musicStatus"
        class="hidden absolute bottom-full right-0 mb-3 max-w-[220px] rounded-2xl border border-slate-200 bg-white/90 px-3 py-2 text-xs font-medium text-slate-600 shadow-lg backdrop-blur dark:border-slate-700 dark:bg-slate-900/90 dark:text-slate-300"
        role="status" aria-live="polite"></div>
    <button onclick="toggleMusic()" id="musicBtn" aria-label="Putar musik latar"
        class="bg-white/80 dark:bg-slate-800/80 backdrop-blur text-brand-accent dark:text-brand-accentLight p-3 md:p-4 rounded-full border border-pink-100 dark:border-slate-700 shadow-lg hover:shadow-xl hover:-translate-y-1 transition-all">
        <i data-lucide="music" id="musicIcon" class="w-5 h-5 md:w-6 md:h-6 transition-transform"></i>
    </button>
    <audio id="bgMusic" loop preload="none" aria-label="Background music player">
        <source src="/music/about-you.mp3" type="audio/mpeg">
    </audio>
</div>
