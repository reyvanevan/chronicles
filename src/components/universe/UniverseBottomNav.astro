---
const { active = 'home', variant = 'glass' } = Astro.props;

const navClass = variant === 'solid'
    ? 'fixed bottom-0 left-0 w-full bg-white dark:bg-slate-900 border-t border-slate-200 dark:border-slate-800 z-50 pb-safe transition-colors duration-300'
    : 'fixed bottom-0 left-0 w-full bg-white/90 dark:bg-slate-900/90 backdrop-blur-lg border-t border-slate-200 dark:border-slate-800 z-50 pb-safe transition-colors duration-300';

const isActive = (tab) => active === tab;
---

<nav class={navClass}>
    <div class="max-w-md mx-auto h-16 grid grid-cols-5 items-center px-3">
        <a href="/universe/home" class={`flex flex-col items-center justify-center w-14 h-full transition group ${isActive('home') ? 'text-pink-500' : 'text-slate-400 hover:text-slate-600 dark:hover:text-slate-200'}`}>
            <i data-lucide="home" class={`w-6 h-6 transition-transform group-hover:scale-110 ${isActive('home') ? 'fill-pink-500/20' : ''}`}></i>
            <span class={`text-[10px] mt-0.5 ${isActive('home') ? 'font-bold' : 'font-medium'}`}>Home</span>
        </a>

        <a href="/universe/daily" class={`flex flex-col items-center justify-center w-14 h-full transition group ${isActive('daily') ? 'text-violet-500' : 'text-slate-400 hover:text-slate-600 dark:hover:text-slate-200'}`}>
            <i data-lucide="orbit" class={`w-6 h-6 transition-transform group-hover:scale-110 ${isActive('daily') ? 'stroke-[3px]' : ''}`}></i>
            <span class={`text-[10px] mt-0.5 ${isActive('daily') ? 'font-bold' : 'font-medium'}`}>Daily</span>
        </a>

        <a href="/universe/explore" class={`flex flex-col items-center justify-center w-14 h-full transition group ${isActive('explore') ? 'text-pink-500' : 'text-slate-400 hover:text-slate-600 dark:hover:text-slate-200'}`}>
            <i data-lucide="search" class={`w-6 h-6 transition-transform group-hover:scale-110 ${isActive('explore') ? 'stroke-[3px]' : ''}`}></i>
            <span class={`text-[10px] mt-0.5 ${isActive('explore') ? 'font-bold' : 'font-medium'}`}>Memories</span>
        </a>

        <a href="/universe/him" class={`flex flex-col items-center justify-center w-14 h-full transition group ${isActive('him') ? 'text-blue-500' : 'text-slate-400 hover:text-blue-500'}`}>
            <i data-lucide="user" class={`w-6 h-6 transition-colors ${isActive('him') ? 'fill-current' : 'group-hover:text-blue-500'}`}></i>
            <span class={`text-[10px] mt-0.5 ${isActive('him') ? 'font-bold' : 'font-medium'}`}>Him</span>
        </a>

        <a href="/universe/her" class={`flex flex-col items-center justify-center w-14 h-full transition group ${isActive('her') ? 'text-pink-500' : 'text-slate-400 hover:text-pink-500'}`}>
            <i data-lucide="heart" class={`w-6 h-6 transition-colors ${isActive('her') ? 'fill-current' : 'group-hover:text-pink-500'}`}></i>
            <span class={`text-[10px] mt-0.5 ${isActive('her') ? 'font-bold' : 'font-medium'}`}>Her</span>
        </a>
    </div>
</nav>
