<div id="storyModal" class="fixed inset-0 z-[100] hidden bg-black">
    <!-- Progress Bars Container -->
    <div id="storyProgressBars" class="absolute top-0 left-0 right-0 z-20 flex gap-1 p-2 px-3">
        <!-- Progress bars will be dynamically inserted -->
    </div>

    <!-- Header -->
    <div class="absolute top-6 left-0 right-0 z-20 px-4 flex items-center justify-between">
        <div class="flex items-center gap-3">
            <img id="storyAuthorAvatar" src="" class="w-8 h-8 rounded-full object-cover border border-white/30">
            <div>
                <p id="storyAuthorName" class="text-white text-sm font-semibold"></p>
                <p id="storyTime" class="text-white/60 text-xs"></p>
            </div>
        </div>
        <button onclick="closeStoryModal()" class="p-2 text-white/80 hover:text-white">
            <i data-lucide="x" class="w-6 h-6"></i>
        </button>
    </div>

    <!-- Story Image -->
    <div class="absolute inset-0 flex items-center justify-center">
        <img id="storyImage" src="" class="max-w-full max-h-full object-contain">
    </div>

    <!-- Navigation Touch Areas -->
    <div class="absolute inset-0 flex z-10">
        <!-- Left (Previous) -->
        <div onclick="prevStory()" class="w-1/3 h-full cursor-pointer"></div>
        <!-- Center (Pause/Play) -->
        <div onclick="toggleStoryPause()" class="w-1/3 h-full cursor-pointer"></div>
        <!-- Right (Next) -->
        <div onclick="nextStory()" class="w-1/3 h-full cursor-pointer"></div>
    </div>

    <!-- Caption (Bottom) -->
    <div class="absolute bottom-0 left-0 right-0 z-20 p-4 pb-8 bg-gradient-to-t from-black/80 to-transparent">
        <p id="storyCaption" class="text-white text-sm text-center"></p>
    </div>

    <!-- Pause Indicator -->
    <div id="pauseIndicator" class="absolute inset-0 hidden items-center justify-center z-30 pointer-events-none">
        <div class="bg-black/50 rounded-full p-4">
            <i data-lucide="pause" class="w-12 h-12 text-white"></i>
        </div>
    </div>
</div>
