<div id="photoModal" class="fixed inset-0 z-[100] hidden">
    <!-- Backdrop -->
    <div class="absolute inset-0 bg-black/90 backdrop-blur-sm" onclick="closePhotoModal()"></div>

    <!-- Modal Content -->
    <div class="absolute inset-0 flex items-center justify-center p-4">
        <!-- Close Button -->
        <button onclick="closePhotoModal()"
            class="absolute top-4 right-4 z-10 p-2 text-white/80 hover:text-white transition">
            <i data-lucide="x" class="w-8 h-8"></i>
        </button>

        <!-- Image Container -->
        <div class="relative max-w-2xl w-full max-h-[90vh] flex flex-col">
            <!-- Image with Carousel Controls -->
            <div class="relative">
                <img id="modalImage" src="" alt="Photo"
                    class="w-full max-h-[70vh] object-contain rounded-t-2xl bg-black">

                <!-- Carousel Navigation (hidden for single images) -->
                <button id="modalPrevBtn" onclick="modalPrevImage()"
                    class="hidden absolute left-3 top-1/2 -translate-y-1/2 z-10 bg-black/50 text-white p-3 rounded-full hover:bg-black/70 transition disabled:opacity-30 disabled:cursor-not-allowed">
                    <i data-lucide="chevron-left" class="w-6 h-6"></i>
                </button>
                <button id="modalNextBtn" onclick="modalNextImage()"
                    class="hidden absolute right-3 top-1/2 -translate-y-1/2 z-10 bg-black/50 text-white p-3 rounded-full hover:bg-black/70 transition disabled:opacity-30 disabled:cursor-not-allowed">
                    <i data-lucide="chevron-right" class="w-6 h-6"></i>
                </button>

                <!-- Image Counter -->
                <div id="modalImageCounter" class="hidden absolute top-4 left-4 bg-black/60 text-white px-3 py-1.5 rounded-full text-sm font-medium">
                    <span>1</span>/<span>1</span>
                </div>

                <!-- Dots Indicator -->
                <div id="modalDots" class="hidden absolute bottom-4 left-1/2 -translate-x-1/2 flex gap-2">
                    <!-- Dots generated by JS -->
                </div>
            </div>

            <!-- Caption & Details -->
            <div id="modalDetails" class="bg-white dark:bg-slate-900 rounded-b-2xl p-4 max-h-[20vh] overflow-y-auto">
                <!-- Author -->
                <div class="flex items-center gap-3 mb-3">
                    <img id="modalAuthorAvatar" src="" class="w-10 h-10 rounded-full object-cover">
                    <div>
                        <p id="modalAuthorName" class="font-bold text-sm"></p>
                        <p id="modalLocation" class="text-xs text-slate-500"></p>
                    </div>
                    <p id="modalTime" class="text-xs text-slate-400 ml-auto"></p>
                </div>

                <!-- Caption -->
                <p id="modalCaption" class="text-sm leading-relaxed"></p>

                <!-- Tags -->
                <div id="modalTags" class="flex gap-2 mt-2 flex-wrap"></div>

                <!-- Actions -->
                <div class="flex items-center gap-4 mt-4 pt-4 border-t border-slate-200 dark:border-slate-800">
                    <button class="flex items-center gap-2 text-slate-600 dark:text-slate-400 hover:text-pink-500 transition">
                        <i data-lucide="heart" class="w-5 h-5"></i>
                        <span id="modalLikes" class="text-sm">0</span>
                    </button>
                    <button class="flex items-center gap-2 text-slate-600 dark:text-slate-400 hover:text-blue-500 transition">
                        <i data-lucide="message-circle" class="w-5 h-5"></i>
                    </button>
                    <button class="flex items-center gap-2 text-slate-600 dark:text-slate-400 hover:text-green-500 transition">
                        <i data-lucide="share-2" class="w-5 h-5"></i>
                    </button>
                    <button class="ml-auto text-slate-600 dark:text-slate-400 hover:text-yellow-500 transition">
                        <i data-lucide="bookmark" class="w-5 h-5"></i>
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>
