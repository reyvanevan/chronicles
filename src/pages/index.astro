---
import Layout from '../layouts/Layout.astro';
import HeroSection from '../components/HeroSection.astro';
import DaysTogetherSection from '../components/DaysTogetherSection.astro';
import AboutSection from '../components/AboutSection.astro';
import GallerySection from '../components/GallerySection.astro';
import MemoriesSection from '../components/MemoriesSection.astro';
import ForeverSection from '../components/ForeverSection.astro';
import MusicPlayer from '../components/MusicPlayer.astro';
---

<Layout title="Home">
    <!-- SCROLL PROGRESS BAR -->
    <div id="scroll-progress-bar"
        class="fixed top-0 left-0 h-1 bg-gradient-to-r from-pink-500 via-purple-500 to-blue-500 z-[60] transition-all duration-100 ease-out shadow-[0_0_10px_rgba(236,72,153,0.5)]"
        style="width: 0%"></div>

    <!-- LIVING BACKGROUND (Fixed across all sections) -->
    <div class="fixed inset-0 z-[-1] overflow-hidden pointer-events-none">
        <div class="absolute top-[-10%] left-[-10%] w-[500px] h-[500px] bg-pink-400/20 dark:bg-pink-900/20 rounded-full blur-[120px] mix-blend-multiply dark:mix-blend-screen animate-blob"></div>
        <div class="absolute top-[20%] right-[-10%] w-[400px] h-[400px] bg-purple-400/20 dark:bg-purple-900/20 rounded-full blur-[120px] mix-blend-multiply dark:mix-blend-screen animate-blob animation-delay-2000"></div>
        <div class="absolute bottom-[-10%] left-[20%] w-[600px] h-[600px] bg-blue-400/20 dark:bg-blue-900/20 rounded-full blur-[120px] mix-blend-multiply dark:mix-blend-screen animate-blob animation-delay-4000"></div>
    </div>

    <main class="pt-16 relative">
        <HeroSection />
        <section id="public-time-preview" class="hidden px-6 py-10 md:px-12 md:py-14">
            <div class="mx-auto max-w-5xl">
                <div class="overflow-hidden rounded-[2rem] border border-white/30 bg-white/55 shadow-[0_20px_80px_rgba(236,72,153,0.12)] backdrop-blur-xl dark:border-white/10 dark:bg-slate-900/55" data-aos="fade-up">
                    <div class="grid gap-0 md:grid-cols-[1.15fr_0.85fr]">
                        <div class="border-b border-white/20 p-6 md:border-b-0 md:border-r md:p-8 dark:border-white/10">
                            <p class="text-[10px] font-bold uppercase tracking-[0.3em] text-pink-500">A living moment</p>
                            <h2 class="mt-3 max-w-lg font-serif text-3xl font-bold leading-tight text-slate-800 dark:text-white md:text-4xl">
                                Time keeps moving, and somehow that makes this story softer.
                            </h2>
                            <p class="mt-4 max-w-xl text-sm leading-7 text-slate-600 dark:text-slate-300 md:text-base">
                                Bukan dashboard. Bukan data mentah. Cuma sedikit potongan waktu yang terus berjalan, sebagai pengingat kalau cerita yang baik selalu tumbuh pelan-pelan.
                            </p>

                            <div class="mt-6 flex flex-wrap gap-3">
                                <div class="rounded-2xl bg-pink-50/80 px-4 py-3 dark:bg-pink-950/30">
                                    <p class="text-[10px] uppercase tracking-[0.2em] text-slate-400">Age right now</p>
                                    <p id="public-age-value" class="mt-1 font-mono text-lg font-semibold text-slate-900 dark:text-white">0.000000000</p>
                                </div>
                                <div class="rounded-2xl bg-blue-50/80 px-4 py-3 dark:bg-blue-950/30">
                                    <p class="text-[10px] uppercase tracking-[0.2em] text-slate-400">Current season</p>
                                    <p id="public-season-value" class="mt-1 text-lg font-semibold text-slate-900 dark:text-white">Summer</p>
                                </div>
                                <div class="rounded-2xl bg-violet-50/80 px-4 py-3 dark:bg-violet-950/30">
                                    <p class="text-[10px] uppercase tracking-[0.2em] text-slate-400">Next milestone</p>
                                    <p id="public-milestone-value" class="mt-1 text-lg font-semibold text-slate-900 dark:text-white">Calculating...</p>
                                </div>
                            </div>
                        </div>

                        <div class="p-6 md:p-8">
                            <div class="space-y-5">
                                <div>
                                    <div class="mb-2 flex items-center justify-between text-sm text-slate-600 dark:text-slate-300">
                                        <span>Life progress</span>
                                        <span id="public-life-progress-value" class="font-semibold text-slate-900 dark:text-white">0%</span>
                                    </div>
                                    <div class="h-2 overflow-hidden rounded-full bg-slate-200/80 dark:bg-slate-800">
                                        <div id="public-life-progress-bar" class="h-full rounded-full bg-gradient-to-r from-pink-500 to-rose-500" style="width: 0%"></div>
                                    </div>
                                </div>

                                <div>
                                    <div class="mb-2 flex items-center justify-between text-sm text-slate-600 dark:text-slate-300">
                                        <span>This year</span>
                                        <span id="public-year-progress-value" class="font-semibold text-slate-900 dark:text-white">0%</span>
                                    </div>
                                    <div class="h-2 overflow-hidden rounded-full bg-slate-200/80 dark:bg-slate-800">
                                        <div id="public-year-progress-bar" class="h-full rounded-full bg-gradient-to-r from-blue-500 to-cyan-500" style="width: 0%"></div>
                                    </div>
                                </div>

                                <div>
                                    <div class="mb-2 flex items-center justify-between text-sm text-slate-600 dark:text-slate-300">
                                        <span>Today</span>
                                        <span id="public-day-progress-value" class="font-semibold text-slate-900 dark:text-white">0%</span>
                                    </div>
                                    <div class="h-2 overflow-hidden rounded-full bg-slate-200/80 dark:bg-slate-800">
                                        <div id="public-day-progress-bar" class="h-full rounded-full bg-gradient-to-r from-violet-500 to-fuchsia-500" style="width: 0%"></div>
                                    </div>
                                </div>
                            </div>

                            <div class="mt-6 rounded-2xl border border-slate-200/70 bg-slate-50/70 p-4 dark:border-slate-800 dark:bg-slate-900/70">
                                <p class="text-[10px] font-bold uppercase tracking-[0.24em] text-slate-400">Quiet note</p>
                                <p id="public-preview-note" class="mt-3 text-sm leading-7 text-slate-600 dark:text-slate-300">
                                    Every passing second becomes part of a longer, gentler archive.
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>
        <DaysTogetherSection />
        <AboutSection />
        <GallerySection />
        <MemoriesSection />
        <ForeverSection />
    </main>

    <MusicPlayer />

    <!-- Firestore Logic -->
    <script>
        
        import { db } from '../lib/firebase-config.js';
        import { doc, getDoc, updateDoc, setDoc, increment } from "firebase/firestore";

        // Track visit (session-based to avoid duplicate counting on refresh)
        async function trackVisit() {
            if (sessionStorage.getItem('visit_counted')) return;
            try {
                const statsRef = doc(db, "landing", "stats");
                await updateDoc(statsRef, { 
                    totalVisits: increment(1) 
                });
                sessionStorage.setItem('visit_counted', 'true');
                console.log('✅ Visit tracked');
            } catch (error) {
                // If document doesn't exist, create it
                if (error.code === 'not-found') {
                    await setDoc(statsRef, { 
                        totalVisits: 1,
                        memoriesCount: 0,
                        startDate: new Date()
                    });
                    sessionStorage.setItem('visit_counted', 'true');
                    console.log('✅ Visit tracked (new document created)');
                } else {
                    console.log('Visit tracking skipped:', error.message);
                }
            }
        }

        // Default fallback data (used when Firestore unavailable)
        const FALLBACK_DATA = {
            profile: {
                photo: 'https://i.ibb.co.com/r2yHqGQc/wallhaven-4vqre8.jpg'
            },
            gallery: [
                { url: 'https://i.ibb.co.com/r2yHqGQc/wallhaven-4vqre8.jpg', caption: 'Favorite Place' },
                { url: 'https://i.ibb.co.com/27nngLbF/wallhaven-m9zvqk.jpg', caption: 'The Day We Laughed' },
                { url: 'https://i.ibb.co.com/0RGkZHkq/af0e12374f7c73be0c9c0e600b42a4c6.jpg', caption: 'A New Chapter' },
                { url: 'https://i.ibb.co.com/NgQR4xMh/Desain-tanpa-judul.png', caption: 'Always Us' }
            ],
            memories: [
                { image: 'https://images.unsplash.com/photo-1516975080664-ed2fc6a32937?ixlib=rb-1.2.1&auto=format&fit=crop&w=800&q=80' },
                { image: 'https://images.unsplash.com/photo-1534528741775-53994a69daeb?ixlib=rb-1.2.1&auto=format&fit=crop&w=800&q=80' }
            ]
        };

        const SITE_FALLBACK_CONFIG = {
            letter: {
                defaultGreeting: 'Untukmu,',
                defaultContent: 'Terima kasih sudah bertahan, tumbuh, dan berjalan bersamaku sampai hari ini.',
                defaultClosing: 'Dengan sayang.'
            },
            about: {
                defaultIntro: 'Di antara banyak kemungkinan, aku bersyukur kita bertemu dan memilih jalan yang sama.',
                traitOneTitle: 'Setia',
                traitOneDescription: 'Tetap hadir bahkan di hari-hari paling berat.',
                traitTwoTitle: 'Bertumbuh',
                traitTwoDescription: 'Berani belajar demi hubungan yang lebih baik.',
                traitThreeTitle: 'Hangat',
                traitThreeDescription: 'Selalu jadi rumah saat dunia terasa ramai.',
                quoteText: 'Semua proses ini selalu terasa layak, selama akhirnya pulang ke kamu.',
                quoteAuthor: 'A Love Note'
            }
        };

        const TIME_PROGRESS_FALLBACK = {
            birthDate: '2002-03-18',
            lifeExpectancyYears: 80,
            breathingRatePerMinute: 15,
            seasons: {
                spring: { min: 0, max: 20, label: 'Learning & Growing' },
                summer: { min: 21, max: 40, label: 'Building & Hustling' },
                autumn: { min: 41, max: 60, label: 'Reflecting & Refining' },
                winter: { min: 61, max: 120, label: 'Legacy & Wisdom' }
            },
            publicPreviewEnabled: true
        };

        const FEATURE_VISIBILITY_FALLBACK = {
            public: {
                progressPreview: true,
                ourStoryProgressPreview: true
            }
        };

        // Load fallback images to prevent skeleton stuck
        function loadFallbackImages() {
            // Profile
            const profileImg = document.getElementById('profile-img');
            if (profileImg) profileImg.src = FALLBACK_DATA.profile.photo;

            // Gallery
            FALLBACK_DATA.gallery.forEach((item, i) => {
                const img = document.getElementById(`gallery-img-${i + 1}`);
                if (img) img.src = item.url;
            });

            // Memories
            FALLBACK_DATA.memories.forEach((item, i) => {
                const img = document.getElementById(`memory-img-${i + 1}`);
                if (img) img.src = item.image;
            });
        }

        async function loadLandingData() {
            try {
                const setText = (id, value) => {
                    const el = document.getElementById(id);
                    if (el && value) el.textContent = value;
                };

                const [configDoc, featureVisibilityDoc] = await Promise.all([
                    getDoc(doc(db, 'config', 'site')),
                    getDoc(doc(db, 'config', 'featureVisibility'))
                ]);
                const cfgRaw = configDoc.exists() ? configDoc.data() : {};
                const visibilityRaw = featureVisibilityDoc.exists() ? featureVisibilityDoc.data() : {};
                const showOurStoryPreview = (visibilityRaw?.public?.ourStoryProgressPreview ?? FEATURE_VISIBILITY_FALLBACK.public.ourStoryProgressPreview) !== false;
                const siteConfig = {
                    startDate: cfgRaw.startDate || '',
                    letter: {
                        ...SITE_FALLBACK_CONFIG.letter,
                        ...(cfgRaw.letter || {})
                    },
                    about: {
                        ...SITE_FALLBACK_CONFIG.about,
                        ...(cfgRaw.about || {})
                    }
                };

                // Apply config-driven fallback for About section
                setText('about-intro-text', siteConfig.about.defaultIntro);
                setText('about-trait-1-title', siteConfig.about.traitOneTitle);
                setText('about-trait-1-description', siteConfig.about.traitOneDescription);
                setText('about-trait-2-title', siteConfig.about.traitTwoTitle);
                setText('about-trait-2-description', siteConfig.about.traitTwoDescription);
                setText('about-trait-3-title', siteConfig.about.traitThreeTitle);
                setText('about-trait-3-description', siteConfig.about.traitThreeDescription);
                setText('about-quote-text', `"${siteConfig.about.quoteText}"`);
                setText('about-quote-author', siteConfig.about.quoteAuthor);

                // Apply config-driven fallback for Forever letter section
                const letterTitleDisplay = document.getElementById('letter-title-display');
                const letterContentDisplay = document.getElementById('letter-content-display');
                const letterQuoteDisplay = document.getElementById('letter-quote-display');
                if (letterTitleDisplay) letterTitleDisplay.textContent = siteConfig.letter.defaultGreeting;
                if (letterContentDisplay) {
                    letterContentDisplay.innerHTML = siteConfig.letter.defaultContent
                        .split('\n')
                        .map((paragraph) => `<p>${paragraph}</p>`)
                        .join('');
                }
                if (letterQuoteDisplay) letterQuoteDisplay.textContent = `"${siteConfig.letter.defaultClosing}"`;

                renderDaysTogetherPreview(siteConfig.startDate, showOurStoryPreview);

                // Load Profile
                const profileDoc = await getDoc(doc(db, "landing", "profile"));
                if (profileDoc.exists()) {
                    const p = profileDoc.data();
                    // Hero section
                    const heroName = document.getElementById('hero-name');
                    if (heroName && p.name) heroName.innerHTML = p.name.split(' ')[0] + ' <span class="text-transparent bg-clip-text bg-gradient-to-r from-pink-400 to-blue-400 dark:from-pink-300 dark:to-blue-300">' + (p.name.split(' ').slice(1).join(' ') || '') + '</span>';

                    // About section
                    const profileImg = document.getElementById('profile-img');
                    const profileBio = document.getElementById('profile-bio');
                    const profileTags = document.getElementById('profile-tags');

                    if (profileImg && p.photo) profileImg.src = p.photo;
                    if (profileBio && p.bio) profileBio.innerHTML = p.bio;
                    if (profileTags && p.tags) {
                        const colors = ['blue', 'pink', 'purple'];
                        profileTags.innerHTML = p.tags.map((tag, i) =>
                            `<span class="px-3 py-1 bg-${colors[i]}-50 dark:bg-${colors[i]}-900/30 text-${colors[i]}-500 dark:text-${colors[i]}-300 rounded-full text-xs font-semibold tracking-wider border border-${colors[i]}-100 dark:border-${colors[i]}-800">#${tag}</span>`
                        ).join('');
                    }
                } else {
                    console.log('ℹ️ Profile document not found, using defaults');
                }

                // Load Gallery
                const galleryDoc = await getDoc(doc(db, "landing", "gallery"));
                if (galleryDoc.exists()) {
                    const g = galleryDoc.data();
                    g.items?.forEach((item, i) => {
                        const img = document.getElementById(`gallery-img-${i + 1}`);
                        const caption = document.getElementById(`gallery-caption-${i + 1}`);
                        if (img && item.url) img.src = item.url;
                        if (caption && item.caption) caption.textContent = item.caption;
                    });
                }

                // Load Memories
                const memoriesDoc = await getDoc(doc(db, "landing", "memories"));
                if (memoriesDoc.exists()) {
                    const m = memoriesDoc.data();
                    m.items?.forEach((item, i) => {
                        const img = document.getElementById(`memory-img-${i + 1}`);
                        const placeholder = document.getElementById(`memory-placeholder-${i + 1}`);
                        const title = document.getElementById(`memory-title-${i + 1}`);
                        const desc = document.getElementById(`memory-desc-${i + 1}`);

                        if (title && item.title) title.textContent = item.title;
                        if (desc && item.description) desc.textContent = item.description;

                        // Handle image and placeholder
                        if (item.image && item.image !== '' && item.image !== null) {
                            // Has valid image - show image, hide placeholder
                            if (img) {
                                img.src = item.image;
                                img.classList.remove('hidden');
                            }
                            if (placeholder) placeholder.classList.add('hidden');
                        } else {
                            // No image - hide image, show placeholder
                            if (img) img.classList.add('hidden');
                            if (placeholder) placeholder.classList.remove('hidden');
                        }
                    });
                }

                // Load Letter
                const letterDoc = await getDoc(doc(db, "landing", "letter"));
                if (letterDoc.exists()) {
                    const letter = letterDoc.data();
                    const letterTitle = document.getElementById('letter-title-display');
                    const letterContent = document.getElementById('letter-content-display');
                    const letterQuote = document.getElementById('letter-quote-display');

                    if (letterTitle && letter.title) letterTitle.textContent = letter.title;
                    if (letterContent && letter.content) letterContent.innerHTML = letter.content.split('\n').map(p => `<p>${p}</p>`).join('');
                    if (letterQuote && letter.quote) letterQuote.textContent = '"' + letter.quote + '"';
                }

                console.log('✅ Landing data loaded from Firestore');
            } catch (error) {
                console.log('Data loading skipped (skeleton remains):', error.message);
            }
        }

        let publicPreviewTimer = null;

        async function loadPublicTimePreview() {
            try {
                const [timeProgressDoc, featureVisibilityDoc] = await Promise.all([
                    getDoc(doc(db, 'config', 'timeProgress')),
                    getDoc(doc(db, 'config', 'featureVisibility'))
                ]);

                const timeProgressConfig = timeProgressDoc.exists()
                    ? {
                        ...TIME_PROGRESS_FALLBACK,
                        ...timeProgressDoc.data(),
                        seasons: {
                            ...TIME_PROGRESS_FALLBACK.seasons,
                            ...(timeProgressDoc.data().seasons || {})
                        }
                    }
                    : TIME_PROGRESS_FALLBACK;

                const featureVisibilityConfig = featureVisibilityDoc.exists()
                    ? {
                        ...FEATURE_VISIBILITY_FALLBACK,
                        ...featureVisibilityDoc.data(),
                        public: {
                            ...FEATURE_VISIBILITY_FALLBACK.public,
                            ...(featureVisibilityDoc.data().public || {})
                        }
                    }
                    : FEATURE_VISIBILITY_FALLBACK;

                const enabled = featureVisibilityConfig.public.progressPreview !== false
                    && timeProgressConfig.publicPreviewEnabled !== false;

                const section = document.getElementById('public-time-preview');
                if (!enabled) {
                    section?.classList.add('hidden');
                    return;
                }

                section?.classList.remove('hidden');
                renderPublicTimePreview(timeProgressConfig);

                if (publicPreviewTimer) clearInterval(publicPreviewTimer);
                publicPreviewTimer = window.setInterval(() => renderPublicTimePreview(timeProgressConfig), 1000);
            } catch (error) {
                console.warn('Public time preview skipped:', error.message);
            }
        }

        function renderPublicTimePreview(config) {
            const now = new Date();
            const birthDate = new Date(`${config.birthDate}T00:00:00`);
            const endOfLife = new Date(birthDate);
            endOfLife.setFullYear(endOfLife.getFullYear() + Number(config.lifeExpectancyYears || 80));

            const livedMs = Math.max(now.getTime() - birthDate.getTime(), 0);
            const lifeSpanMs = Math.max(endOfLife.getTime() - birthDate.getTime(), 1);
            const ageYears = livedMs / (365.2425 * 24 * 60 * 60 * 1000);
            const lifeProgress = (livedMs / lifeSpanMs) * 100;

            const lastBirthday = new Date(now.getFullYear(), birthDate.getMonth(), birthDate.getDate());
            const nextBirthday = new Date(now.getFullYear(), birthDate.getMonth(), birthDate.getDate());
            if (now >= nextBirthday) nextBirthday.setFullYear(nextBirthday.getFullYear() + 1);
            if (now < lastBirthday) lastBirthday.setFullYear(lastBirthday.getFullYear() - 1);

            const yearProgress = ((now.getTime() - lastBirthday.getTime()) / Math.max(nextBirthday.getTime() - lastBirthday.getTime(), 1)) * 100;
            const startOfDay = new Date(now.getFullYear(), now.getMonth(), now.getDate());
            const endOfDay = new Date(now.getFullYear(), now.getMonth(), now.getDate() + 1);
            const dayProgress = ((now.getTime() - startOfDay.getTime()) / Math.max(endOfDay.getTime() - startOfDay.getTime(), 1)) * 100;
            const currentAge = Math.floor(ageYears);
            const season = getPublicSeasonLabel(currentAge, config.seasons);
            const daysToBirthday = Math.ceil((nextBirthday.getTime() - now.getTime()) / 86400000);

            setPublicText('public-age-value', ageYears.toFixed(9));
            setPublicText('public-season-value', season);
            setPublicText('public-milestone-value', `H-${Math.max(daysToBirthday, 0)} to next birthday`);
            setPublicText('public-preview-note', buildPublicPreviewNote(season, lifeProgress));
            setPublicProgress('public-life-progress-bar', 'public-life-progress-value', lifeProgress);
            setPublicProgress('public-year-progress-bar', 'public-year-progress-value', yearProgress);
            setPublicProgress('public-day-progress-bar', 'public-day-progress-value', dayProgress);
        }

        function getPublicSeasonLabel(age, seasons) {
            const seasonEntries = Object.values(seasons || {});
            const matched = seasonEntries.find((entry) => age >= entry.min && age <= entry.max);
            return matched?.label || 'Still unfolding';
        }

        function buildPublicPreviewNote(season, lifeProgress) {
            if (lifeProgress >= 70) {
                return `Deep into ${season}, and still collecting beautiful reasons to stay soft.`;
            }
            if (lifeProgress >= 40) {
                return `Somewhere inside ${season}, with enough room left for wonder, repair, and warmth.`;
            }
            return `Still early in ${season}, where almost everything meaningful is quietly taking shape.`;
        }

        function setPublicText(id, value) {
            const el = document.getElementById(id);
            if (el) el.textContent = value;
        }

        function setPublicProgress(barId, labelId, value) {
            const safeValue = `${Math.min(Math.max(value, 0), 100).toFixed(2)}%`;
            const bar = document.getElementById(barId);
            const label = document.getElementById(labelId);
            if (bar) bar.style.width = safeValue;
            if (label) label.textContent = safeValue;
        }

        function renderDaysTogetherPreview(startDateValue, isVisible = true) {
            const section = document.getElementById('days-together-section');
            const daysText = document.getElementById('landing-days-together');
            const noteText = document.getElementById('landing-days-together-note');
            const sinceText = document.getElementById('landing-since-date');
            const nextAnniversaryText = document.getElementById('landing-next-anniversary');
            const nextAnniversaryDateText = document.getElementById('landing-next-anniversary-date');

            if (!section || !daysText || !noteText || !sinceText || !nextAnniversaryText || !nextAnniversaryDateText) return;

            if (!isVisible) {
                section.classList.add('hidden');
                return;
            }

            if (!startDateValue) {
                section.classList.add('hidden');
                return;
            }

            const startDate = new Date(`${startDateValue}T00:00:00`);
            if (Number.isNaN(startDate.getTime())) {
                section.classList.add('hidden');
                return;
            }

            section.classList.remove('hidden');

            const now = new Date();
            const daysTogether = Math.max(Math.floor((now.getTime() - startDate.getTime()) / 86400000), 0);

            const nextAnniversary = new Date(startDate);
            nextAnniversary.setFullYear(now.getFullYear());
            nextAnniversary.setHours(0, 0, 0, 0);
            if (nextAnniversary.getTime() <= now.getTime()) {
                nextAnniversary.setFullYear(now.getFullYear() + 1);
            }

            const daysToAnniversary = Math.max(Math.ceil((nextAnniversary.getTime() - now.getTime()) / 86400000), 0);

            daysText.textContent = `${daysTogether.toLocaleString('id-ID')} hari`;
            sinceText.textContent = startDate.toLocaleDateString('id-ID', {
                day: '2-digit',
                month: 'short',
                year: 'numeric'
            });
            nextAnniversaryText.textContent = `H-${daysToAnniversary}`;
            nextAnniversaryDateText.textContent = nextAnniversary.toLocaleDateString('id-ID', {
                weekday: 'long',
                day: 'numeric',
                month: 'long',
                year: 'numeric'
            });

            if (daysToAnniversary <= 7) {
                noteText.textContent = 'Minggu anniversary udah deket. Mungkin ini waktunya siapin hal kecil yang bikin dia senyum lebih lama.';
                return;
            }
            if (daysToAnniversary <= 30) {
                noteText.textContent = 'Hitung mundur udah mulai kerasa. Nggak harus mewah, cukup jadi hari yang bikin hati tenang.';
                return;
            }
            noteText.textContent = 'Setiap hari yang lewat tetap kita hitung, bukan karena takut lupa, tapi karena ini memang layak dirayakan pelan-pelan.';
        }

        // Run on page load
        trackVisit();
        loadLandingData();
        loadPublicTimePreview();
        
        // Music control
        const bgMusic = document.getElementById('bgMusic');
        const musicBtn = document.getElementById('musicBtn');
        const musicIcon = document.getElementById('musicIcon');
        let isPlaying = false;
        
        window.toggleMusic = function() {
            if (isPlaying) {
                bgMusic.pause();
                isPlaying = false;
                musicIcon.classList.remove('animate-spin');
                musicBtn.classList.remove('ring-2', 'ring-pink-500/50');
            } else {
                bgMusic.play().catch(e => console.log('Play error:', e));
                isPlaying = true;
                musicIcon.classList.add('animate-spin');
                musicBtn.classList.add('ring-2', 'ring-pink-500/50');
            }
        };
    
    </script>
    <script>
        // Universe access trigger: 5 taps on the navbar logo.
        let logoClicks = 0;
        let clickTimer;
        const logoTrigger = document.getElementById('secret-login-trigger');

        logoTrigger.addEventListener('click', (e) => {
            e.preventDefault();
            logoClicks++;

            clearTimeout(clickTimer);
            clickTimer = setTimeout(() => {
                logoClicks = 0;
            }, 2000);

            if (logoClicks === 5) {
                const referrer = document.referrer;
                if (referrer && referrer.includes('/universe/')) {
                    window.location.href = '/universe/login';
                } else {
                    window.location.href = 'universe/';
                }
                logoClicks = 0;
            }
        });

        // Scroll Progress Bar
        window.addEventListener('scroll', () => {
            const totalScroll = document.documentElement.scrollTop;
            const windowHeight = document.documentElement.scrollHeight - document.documentElement.clientHeight;
            const scroll = totalScroll / windowHeight;
            const progressBar = document.getElementById('scroll-progress-bar');
            if (progressBar) {
                progressBar.style.width = `${scroll * 100}%`;
            }
        });
    
    </script>
</Layout>
