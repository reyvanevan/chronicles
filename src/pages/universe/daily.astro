---
import '../../styles/global.css';
import UniverseBottomNav from '../../components/universe/UniverseBottomNav.astro';

// Dedicated page for daily widgets and reminders
---

<!DOCTYPE html>
<html lang="id" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Daily Orbit</title>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,600;0,700;1,600&display=swap" rel="stylesheet">
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">
    <script is:inline src="https://unpkg.com/lucide@latest"></script>

    <script is:inline>
        if (localStorage.theme === 'dark' || (!('theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
            document.documentElement.classList.add('dark');
        } else {
            document.documentElement.classList.remove('dark');
        }
    </script>
</head>
<body class="bg-gradient-to-br from-brand-blue via-slate-50 to-brand-pink dark:from-slate-950 dark:via-slate-900 dark:to-slate-950 min-h-screen text-slate-700 dark:text-slate-300 selection:bg-brand-pink selection:text-brand-accent">

    <header class="fixed top-0 left-0 w-full z-50 bg-white/90 dark:bg-slate-900/90 backdrop-blur-md border-b border-slate-200 dark:border-slate-800 transition-colors duration-300">
        <div class="max-w-md mx-auto px-4 h-16 flex justify-between items-center">
            <a href="/universe/home" class="flex items-center gap-2">
                <i data-lucide="globe-2" class="w-5 h-5 text-violet-500"></i>
                <span class="font-serif font-bold text-lg tracking-tight">Chronicles</span>
            </a>

            <div class="flex items-center gap-3">
                <button onclick="toggleTheme()" class="p-2 rounded-full hover:bg-slate-100 dark:hover:bg-slate-800 transition">
                    <i data-lucide="sun" class="w-5 h-5 text-amber-500 hidden dark:block"></i>
                    <i data-lucide="moon" class="w-5 h-5 text-slate-600 block dark:hidden"></i>
                </button>
                <button onclick="handleLogout()" class="p-2 rounded-full hover:bg-red-50 dark:hover:bg-red-900/20 transition" title="Logout">
                    <i data-lucide="log-out" class="w-5 h-5 text-red-500"></i>
                </button>
            </div>
        </div>
    </header>

    <main class="max-w-md mx-auto pt-20 px-4 space-y-6 pb-28">
        <section class="rounded-3xl border border-violet-200/70 bg-gradient-to-r from-violet-50/70 to-indigo-50/70 p-5 shadow-sm dark:border-violet-900/40 dark:from-violet-950/20 dark:to-slate-900" data-aos="fade-up">
            <p class="text-[11px] font-semibold uppercase tracking-[0.24em] text-violet-500/80">Daily Space</p>
            <h1 class="mt-2 font-serif text-2xl font-bold text-slate-800 dark:text-white">Orbit, progress, and notes in one page</h1>
            <p class="mt-2 text-sm text-slate-500 dark:text-slate-400">Ruang khusus untuk rutinitas harian, jadi home tetap fokus ke feed memories.</p>
        </section>

        <section id="lifeWidgetsSection" class="hidden space-y-4" data-aos="fade-up" data-aos-delay="40">
            <div class="rounded-3xl border border-slate-200/70 bg-white/90 p-5 shadow-sm backdrop-blur-sm dark:border-slate-800 dark:bg-slate-900/90">
                <div class="flex items-start justify-between gap-4">
                    <div>
                        <p class="text-[11px] font-semibold uppercase tracking-[0.24em] text-slate-400">Daily Orbit</p>
                        <h2 class="mt-2 font-serif text-2xl font-bold text-slate-800 dark:text-white">A little desk for today</h2>
                        <p id="dailyDateLabel" class="mt-1 text-sm text-slate-500 dark:text-slate-400"></p>
                    </div>
                    <div class="rounded-2xl bg-slate-100/80 px-4 py-3 text-right dark:bg-slate-800/80">
                        <p class="text-[11px] uppercase tracking-[0.2em] text-slate-400">Local Time</p>
                        <p id="digitalClockValue" class="mt-1 font-mono text-xl font-semibold text-slate-800 dark:text-white">--:--:--</p>
                    </div>
                </div>

                <div class="mt-5 grid grid-cols-[1.4fr_1fr] gap-3">
                    <div class="rounded-2xl bg-gradient-to-br from-pink-50 to-rose-50 p-4 dark:from-pink-950/40 dark:to-slate-900">
                        <div class="flex items-center gap-2 text-pink-500">
                            <i data-lucide="sparkles" class="h-4 w-4"></i>
                            <span class="text-xs font-semibold uppercase tracking-[0.16em]">Dynamic Age</span>
                        </div>
                        <p id="dynamicAgeValue" class="mt-3 break-all font-mono text-2xl font-semibold text-slate-900 dark:text-white">0.000000000</p>
                        <p class="mt-1 text-xs text-slate-500 dark:text-slate-400">Years old, and still counting.</p>
                    </div>

                    <div class="rounded-2xl bg-slate-50 p-4 dark:bg-slate-800/80">
                        <div class="flex items-center gap-2 text-blue-500">
                            <i data-lucide="cloud-sun" class="h-4 w-4"></i>
                            <span class="text-xs font-semibold uppercase tracking-[0.16em]">Weather</span>
                        </div>
                        <p id="weatherValue" class="mt-3 text-lg font-semibold text-slate-900 dark:text-white">Loading...</p>
                        <p id="weatherSubtext" class="mt-1 text-xs text-slate-500 dark:text-slate-400">Trying to find your sky.</p>
                    </div>
                </div>

                <div class="mt-4 rounded-2xl border border-slate-200/70 p-4 dark:border-slate-700">
                    <div class="flex items-center justify-between gap-3">
                        <div>
                            <p class="text-xs font-semibold uppercase tracking-[0.16em] text-slate-400">Current Season</p>
                            <p id="seasonValue" class="mt-1 font-serif text-xl font-semibold text-slate-800 dark:text-white">Summer</p>
                        </div>
                        <div class="text-right">
                            <p class="text-xs font-semibold uppercase tracking-[0.16em] text-slate-400">Next Milestone</p>
                            <p id="nextMilestoneValue" class="mt-1 text-sm font-medium text-slate-700 dark:text-slate-200">Calculating...</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="rounded-3xl border border-slate-200/70 bg-white/90 p-5 shadow-sm dark:border-slate-800 dark:bg-slate-900/90">
                <div class="mb-4 flex items-center justify-between gap-3">
                    <div>
                        <p class="text-[11px] font-semibold uppercase tracking-[0.24em] text-slate-400">Life Progress</p>
                        <h3 class="mt-1 font-serif text-xl font-bold text-slate-800 dark:text-white">Measured in motion</h3>
                    </div>
                </div>

                <div class="space-y-4">
                    <div>
                        <div class="mb-2 flex items-center justify-between text-sm">
                            <span class="font-medium text-slate-600 dark:text-slate-300">Life</span>
                            <span id="lifeProgressValue" class="font-semibold text-slate-800 dark:text-white">0%</span>
                        </div>
                        <div class="h-2 overflow-hidden rounded-full bg-slate-200 dark:bg-slate-800">
                            <div id="lifeProgressBar" class="h-full rounded-full bg-gradient-to-r from-pink-500 to-rose-500" style="width: 0%"></div>
                        </div>
                    </div>

                    <div>
                        <div class="mb-2 flex items-center justify-between text-sm">
                            <span class="font-medium text-slate-600 dark:text-slate-300">Current Year</span>
                            <span id="yearProgressValue" class="font-semibold text-slate-800 dark:text-white">0%</span>
                        </div>
                        <div class="h-2 overflow-hidden rounded-full bg-slate-200 dark:bg-slate-800">
                            <div id="yearProgressBar" class="h-full rounded-full bg-gradient-to-r from-blue-500 to-cyan-500" style="width: 0%"></div>
                        </div>
                    </div>

                    <div>
                        <div class="mb-2 flex items-center justify-between text-sm">
                            <span class="font-medium text-slate-600 dark:text-slate-300">Today</span>
                            <span id="dayProgressValue" class="font-semibold text-slate-800 dark:text-white">0%</span>
                        </div>
                        <div class="h-2 overflow-hidden rounded-full bg-slate-200 dark:bg-slate-800">
                            <div id="dayProgressBar" class="h-full rounded-full bg-gradient-to-r from-violet-500 to-fuchsia-500" style="width: 0%"></div>
                        </div>
                    </div>
                </div>

                <div class="mt-5 grid grid-cols-2 gap-3 sm:grid-cols-4">
                    <div class="rounded-2xl bg-slate-50 p-3 dark:bg-slate-800/80">
                        <p class="text-[11px] uppercase tracking-[0.16em] text-slate-400">Days</p>
                        <p id="totalDaysValue" class="mt-2 text-lg font-semibold text-slate-900 dark:text-white">0</p>
                    </div>
                    <div class="rounded-2xl bg-slate-50 p-3 dark:bg-slate-800/80">
                        <p class="text-[11px] uppercase tracking-[0.16em] text-slate-400">Hours</p>
                        <p id="totalHoursValue" class="mt-2 text-lg font-semibold text-slate-900 dark:text-white">0</p>
                    </div>
                    <div class="rounded-2xl bg-slate-50 p-3 dark:bg-slate-800/80">
                        <p class="text-[11px] uppercase tracking-[0.16em] text-slate-400">Breaths</p>
                        <p id="totalBreathsValue" class="mt-2 text-lg font-semibold text-slate-900 dark:text-white">0</p>
                    </div>
                    <div class="rounded-2xl bg-slate-50 p-3 dark:bg-slate-800/80">
                        <p class="text-[11px] uppercase tracking-[0.16em] text-slate-400">Preview</p>
                        <p id="publicPreviewStatus" class="mt-2 text-sm font-semibold text-slate-900 dark:text-white">Enabled</p>
                    </div>
                </div>
            </div>
        </section>

        <section id="quickNotesSection" class="hidden space-y-4" data-aos="fade-up" data-aos-delay="80">
            <div class="rounded-3xl border border-slate-200/70 bg-white/90 p-5 shadow-sm dark:border-slate-800 dark:bg-slate-900/90">
                <div class="flex items-start justify-between gap-4">
                    <div>
                        <p class="text-[11px] font-semibold uppercase tracking-[0.24em] text-slate-400">Desk Notes</p>
                        <h3 class="mt-1 font-serif text-2xl font-bold text-slate-800 dark:text-white">Quick reminders for this orbit</h3>
                        <p class="mt-2 text-sm text-slate-500 dark:text-slate-400">Catat hal kecil sebelum lewat. Bisa buat checklist, note lucu, atau reminder sederhana.</p>
                    </div>
                    <div class="rounded-2xl bg-amber-50 px-4 py-3 text-right dark:bg-amber-950/20">
                        <p class="text-[11px] uppercase tracking-[0.16em] text-slate-400">Open Notes</p>
                        <p id="quickNotesOpenCount" class="mt-1 text-xl font-semibold text-slate-900 dark:text-white">0</p>
                    </div>
                </div>

                <div class="mt-5 grid grid-cols-3 gap-3">
                    <div class="rounded-2xl bg-slate-50 p-3 dark:bg-slate-800/80">
                        <p class="text-[11px] uppercase tracking-[0.16em] text-slate-400">Total</p>
                        <p id="quickNotesTotalCount" class="mt-2 text-lg font-semibold text-slate-900 dark:text-white">0</p>
                    </div>
                    <div class="rounded-2xl bg-slate-50 p-3 dark:bg-slate-800/80">
                        <p class="text-[11px] uppercase tracking-[0.16em] text-slate-400">Pinned</p>
                        <p id="quickNotesPinnedCount" class="mt-2 text-lg font-semibold text-slate-900 dark:text-white">0</p>
                    </div>
                    <div class="rounded-2xl bg-slate-50 p-3 dark:bg-slate-800/80">
                        <p class="text-[11px] uppercase tracking-[0.16em] text-slate-400">Done</p>
                        <p id="quickNotesDoneCount" class="mt-2 text-lg font-semibold text-slate-900 dark:text-white">0</p>
                    </div>
                </div>

                <form id="quickNoteForm" class="mt-5 space-y-3" onsubmit="submitQuickNote(event)">
                    <input id="quickNoteTitle" type="text" maxlength="80" placeholder="Judul singkat, misal: jangan lupa kirim voice note"
                        class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-800 outline-none transition focus:border-pink-400 focus:ring-2 focus:ring-pink-400/30 dark:border-slate-700 dark:bg-slate-800 dark:text-slate-100">
                    <textarea id="quickNoteContent" rows="3" maxlength="280" placeholder="Isi catatan atau reminder kecil untuk hari ini..."
                        class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-800 outline-none transition focus:border-pink-400 focus:ring-2 focus:ring-pink-400/30 dark:border-slate-700 dark:bg-slate-800 dark:text-slate-100"></textarea>
                    <div class="grid grid-cols-[1fr_auto] gap-3">
                        <label class="rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-500 dark:border-slate-700 dark:bg-slate-800 dark:text-slate-300">
                            <span class="mb-2 block text-[11px] font-semibold uppercase tracking-[0.16em] text-slate-400">Due date</span>
                            <input id="quickNoteDueDate" type="date" class="w-full bg-transparent text-sm text-slate-800 outline-none dark:text-slate-100">
                        </label>
                        <label class="flex items-center gap-3 rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-600 dark:border-slate-700 dark:bg-slate-800 dark:text-slate-300">
                            <input id="quickNotePinned" type="checkbox" class="h-4 w-4 rounded border-slate-300 text-pink-500 focus:ring-pink-500">
                            <span>Pin</span>
                        </label>
                    </div>
                    <div class="flex items-center justify-between gap-3">
                        <p id="quickNoteFeedback" class="hidden text-sm"></p>
                        <button id="quickNoteSubmitButton" type="submit" class="inline-flex items-center gap-2 rounded-full bg-pink-500 px-5 py-3 text-sm font-semibold text-white shadow-lg shadow-pink-500/20 transition hover:bg-pink-600">
                            <i data-lucide="notebook-pen" class="h-4 w-4"></i>
                            Save note
                        </button>
                    </div>
                </form>
            </div>

            <div id="quickNotesEmptyState" class="hidden rounded-3xl border border-dashed border-slate-300/80 bg-white/70 p-8 text-center dark:border-slate-700 dark:bg-slate-900/70">
                <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-full bg-slate-100 dark:bg-slate-800">
                    <i data-lucide="sticky-note" class="h-6 w-6 text-slate-400"></i>
                </div>
                <h4 class="mt-4 font-serif text-xl font-bold text-slate-800 dark:text-white">No notes yet</h4>
                <p class="mt-2 text-sm text-slate-500 dark:text-slate-400">Tulis reminder pertama supaya ruang kecil ini mulai terasa hidup.</p>
            </div>

            <div id="quickNotesList" class="space-y-3"></div>
        </section>
    </main>

    <UniverseBottomNav active="daily" variant="solid" />

    <script>
        import { auth } from '../../lib/firebase-config.js';
        import { onAuthStateChanged } from 'firebase/auth';
        import { formatRelativeTime, getCurrentAuthor, logout, getQuickNotes, createQuickNote, updateQuickNote, deleteQuickNote } from '../../lib/firestore-service.js';
        import { ensureFeatureConfigDefaults, loadFeatureVisibilityConfig, loadTimeProgressConfig } from '../../lib/cms/config.ts';

        let lifeWidgetTimer = null;
        let quickNotesState = [];

        window.handleLogout = async function() {
            if (!confirm('Yakin mau logout?')) return;

            try {
                await logout();
            } catch (error) {
                alert('Error logout: ' + error.message);
            }
        };

        onAuthStateChanged(auth, async (user) => {
            if (!user) {
                window.location.href = '/universe/login';
                return;
            }

            window.currentAuthor = getCurrentAuthor(user);
            await ensureFeatureConfigDefaults();
            await loadLifeWidgets();
            await loadQuickNotesModule();
            lucide.createIcons();
        });

        async function loadLifeWidgets() {
            try {
                const [timeConfig, visibilityConfig] = await Promise.all([
                    loadTimeProgressConfig(),
                    loadFeatureVisibilityConfig()
                ]);

                const section = document.getElementById('lifeWidgetsSection');
                const widgetsEnabled = visibilityConfig?.universe?.progressWidgets !== false;
                const dashboardEnabled = visibilityConfig?.universe?.dailyDashboard !== false;

                if (!widgetsEnabled && !dashboardEnabled) {
                    section?.classList.add('hidden');
                    return;
                }

                section?.classList.remove('hidden');
                renderWeatherWidget();
                updateLifeWidgets(timeConfig);

                if (lifeWidgetTimer) clearInterval(lifeWidgetTimer);
                lifeWidgetTimer = window.setInterval(() => updateLifeWidgets(timeConfig), 1000);
            } catch (error) {
                console.error('Failed to load life widgets:', error);
            }
        }

        function updateLifeWidgets(config) {
            const now = new Date();
            const birthDate = new Date(`${config.birthDate}T00:00:00`);
            const endOfLife = new Date(birthDate);
            endOfLife.setFullYear(endOfLife.getFullYear() + Number(config.lifeExpectancyYears || 80));

            const livedMs = Math.max(now.getTime() - birthDate.getTime(), 0);
            const lifeSpanMs = Math.max(endOfLife.getTime() - birthDate.getTime(), 1);
            const dynamicAgeYears = livedMs / (365.2425 * 24 * 60 * 60 * 1000);
            const totalDays = livedMs / 86400000;
            const totalHours = livedMs / 3600000;
            const totalBreaths = totalHours * 60 * Number(config.breathingRatePerMinute || 15);

            const lastBirthday = new Date(now.getFullYear(), birthDate.getMonth(), birthDate.getDate());
            const nextBirthday = new Date(now.getFullYear(), birthDate.getMonth(), birthDate.getDate());
            if (now >= nextBirthday) {
                nextBirthday.setFullYear(nextBirthday.getFullYear() + 1);
            }
            if (now < lastBirthday) {
                lastBirthday.setFullYear(lastBirthday.getFullYear() - 1);
            }

            const yearProgress = ((now.getTime() - lastBirthday.getTime()) / Math.max(nextBirthday.getTime() - lastBirthday.getTime(), 1)) * 100;
            const startOfDay = new Date(now.getFullYear(), now.getMonth(), now.getDate());
            const endOfDay = new Date(now.getFullYear(), now.getMonth(), now.getDate() + 1);
            const dayProgress = ((now.getTime() - startOfDay.getTime()) / (endOfDay.getTime() - startOfDay.getTime())) * 100;
            const lifeProgress = (livedMs / lifeSpanMs) * 100;
            const currentAge = Math.floor(dynamicAgeYears);
            const daysUntilBirthday = Math.ceil((nextBirthday.getTime() - now.getTime()) / 86400000);

            const seasonLabel = getSeasonLabel(currentAge, config.seasons);
            const formattedDate = now.toLocaleDateString('en-US', {
                weekday: 'long',
                month: 'long',
                day: 'numeric',
                year: 'numeric'
            });

            setText('digitalClockValue', now.toLocaleTimeString('en-GB'));
            setText('dailyDateLabel', formattedDate);
            setText('dynamicAgeValue', dynamicAgeYears.toFixed(9));
            setText('seasonValue', seasonLabel);
            setText('nextMilestoneValue', `H-${Math.max(daysUntilBirthday, 0)} to next birthday`);

            setProgress('lifeProgressBar', 'lifeProgressValue', lifeProgress);
            setProgress('yearProgressBar', 'yearProgressValue', yearProgress);
            setProgress('dayProgressBar', 'dayProgressValue', dayProgress);

            setText('totalDaysValue', Math.floor(totalDays).toLocaleString());
            setText('totalHoursValue', Math.floor(totalHours).toLocaleString());
            setText('totalBreathsValue', Math.floor(totalBreaths).toLocaleString());
            setText('publicPreviewStatus', config.publicPreviewEnabled ? 'Enabled' : 'Hidden');
        }

        function getSeasonLabel(age, seasons) {
            const seasonEntries = Object.values(seasons || {});
            const matched = seasonEntries.find((entry) => age >= entry.min && age <= entry.max);
            return matched?.label || 'Still unfolding';
        }

        function setText(id, value) {
            const element = document.getElementById(id);
            if (element) element.textContent = value;
        }

        function setProgress(barId, labelId, value) {
            const safeValue = `${Math.min(Math.max(value, 0), 100).toFixed(2)}%`;
            const bar = document.getElementById(barId);
            const label = document.getElementById(labelId);
            if (bar) bar.style.width = safeValue;
            if (label) label.textContent = safeValue;
        }

        async function renderWeatherWidget() {
            const weatherValue = document.getElementById('weatherValue');
            const weatherSubtext = document.getElementById('weatherSubtext');
            if (!weatherValue || !weatherSubtext || !navigator.geolocation) {
                setText('weatherValue', 'No weather');
                setText('weatherSubtext', 'Location not available.');
                return;
            }

            navigator.geolocation.getCurrentPosition(async (position) => {
                try {
                    const { latitude, longitude } = position.coords;
                    const response = await fetch(`https://api.open-meteo.com/v1/forecast?latitude=${latitude}&longitude=${longitude}&current=temperature_2m,weather_code&timezone=auto`);
                    const data = await response.json();
                    const temperature = Math.round(data?.current?.temperature_2m ?? 0);
                    const condition = mapWeatherCode(data?.current?.weather_code);
                    setText('weatherValue', `${temperature}°C · ${condition}`);
                    setText('weatherSubtext', 'Live from your current location.');
                } catch (error) {
                    console.warn('Weather fetch failed:', error);
                    setText('weatherValue', 'Weather unavailable');
                    setText('weatherSubtext', 'Could not fetch the forecast.');
                }
            }, () => {
                setText('weatherValue', 'Weather locked');
                setText('weatherSubtext', 'Enable location to see your sky.');
            }, { timeout: 5000 });
        }

        function mapWeatherCode(code) {
            const weatherMap = {
                0: 'Clear',
                1: 'Mostly Clear',
                2: 'Partly Cloudy',
                3: 'Cloudy',
                45: 'Foggy',
                48: 'Rime Fog',
                51: 'Light Drizzle',
                53: 'Drizzle',
                55: 'Heavy Drizzle',
                61: 'Light Rain',
                63: 'Rain',
                65: 'Heavy Rain',
                71: 'Light Snow',
                80: 'Rain Showers',
                95: 'Thunderstorm'
            };
            return weatherMap[code] || 'Unknown';
        }

        async function loadQuickNotesModule() {
            try {
                const visibilityConfig = await loadFeatureVisibilityConfig();
                const section = document.getElementById('quickNotesSection');
                const enabled = visibilityConfig?.universe?.notesAndReminders !== false;

                if (!enabled) {
                    section?.classList.add('hidden');
                    return;
                }

                section?.classList.remove('hidden');
                await refreshQuickNotes();
            } catch (error) {
                console.error('Failed to load quick notes module:', error);
            }
        }

        async function refreshQuickNotes() {
            try {
                quickNotesState = await getQuickNotes(50, window.currentAuthor);
                renderQuickNotes();
            } catch (error) {
                console.error('Failed to refresh quick notes:', error);
                setQuickNoteFeedback('Gagal memuat notes. Coba refresh sebentar lagi.', 'error');
            }
        }

        function renderQuickNotes() {
            const list = document.getElementById('quickNotesList');
            const emptyState = document.getElementById('quickNotesEmptyState');
            if (!list || !emptyState) return;

            const sortedNotes = [...quickNotesState].sort((left, right) => {
                if (!!left.isPinned !== !!right.isPinned) return left.isPinned ? -1 : 1;
                const leftTime = left.updatedAt ? new Date(left.updatedAt).getTime() : 0;
                const rightTime = right.updatedAt ? new Date(right.updatedAt).getTime() : 0;
                return rightTime - leftTime;
            });

            if (sortedNotes.length === 0) {
                list.innerHTML = '';
                emptyState.classList.remove('hidden');
            } else {
                emptyState.classList.add('hidden');
                list.innerHTML = sortedNotes.map((note) => renderQuickNoteCard(note)).join('');
            }

            setText('quickNotesTotalCount', String(sortedNotes.length));
            setText('quickNotesOpenCount', String(sortedNotes.filter((note) => note.status !== 'done').length));
            setText('quickNotesPinnedCount', String(sortedNotes.filter((note) => !!note.isPinned).length));
            setText('quickNotesDoneCount', String(sortedNotes.filter((note) => note.status === 'done').length));
            lucide.createIcons();
        }

        function renderQuickNoteCard(note) {
            const dueText = formatQuickNoteDueDate(note.dueDate);
            const title = escapeHtml(note.title || 'Untitled note');
            const content = escapeHtml(note.content || 'No details yet.');
            const done = note.status === 'done';

            return `
                <article class="rounded-3xl border ${done ? 'border-emerald-200/70 bg-emerald-50/70 dark:border-emerald-900/40 dark:bg-emerald-950/10' : 'border-slate-200/70 bg-white/90 dark:border-slate-800 dark:bg-slate-900/90'} p-4 shadow-sm transition" data-note-id="${note.id}">
                    <div class="flex items-start justify-between gap-3">
                        <div class="min-w-0 flex-1">
                            <div class="flex flex-wrap items-center gap-2">
                                <h4 class="font-semibold text-slate-900 dark:text-white ${done ? 'line-through opacity-70' : ''}">${title}</h4>
                                ${note.isPinned ? '<span class="rounded-full bg-pink-100 px-2 py-1 text-[10px] font-semibold uppercase tracking-[0.16em] text-pink-600 dark:bg-pink-950/40 dark:text-pink-300">Pinned</span>' : ''}
                                ${done ? '<span class="rounded-full bg-emerald-100 px-2 py-1 text-[10px] font-semibold uppercase tracking-[0.16em] text-emerald-600 dark:bg-emerald-950/40 dark:text-emerald-300">Done</span>' : '<span class="rounded-full bg-amber-100 px-2 py-1 text-[10px] font-semibold uppercase tracking-[0.16em] text-amber-600 dark:bg-amber-950/40 dark:text-amber-300">Open</span>'}
                            </div>
                            <p class="mt-3 whitespace-pre-wrap text-sm leading-6 text-slate-600 dark:text-slate-300 ${done ? 'opacity-80' : ''}">${content}</p>
                            <div class="mt-4 flex flex-wrap items-center gap-3 text-xs text-slate-400">
                                <span class="inline-flex items-center gap-1"><i data-lucide="calendar-clock" class="h-3.5 w-3.5"></i>${dueText}</span>
                                <span class="inline-flex items-center gap-1"><i data-lucide="history" class="h-3.5 w-3.5"></i>${formatQuickNoteTime(note.updatedAt || note.createdAt)}</span>
                            </div>
                        </div>
                        <div class="flex shrink-0 flex-col gap-2">
                            <button type="button" onclick="toggleQuickNotePin('${note.id}')" class="rounded-full p-2 text-slate-400 transition hover:bg-slate-100 hover:text-pink-500 dark:hover:bg-slate-800" aria-label="Toggle pin">
                                <i data-lucide="pin${note.isPinned ? '-off' : ''}" class="h-4 w-4"></i>
                            </button>
                            <button type="button" onclick="toggleQuickNoteStatus('${note.id}')" class="rounded-full p-2 text-slate-400 transition hover:bg-slate-100 hover:text-emerald-500 dark:hover:bg-slate-800" aria-label="Toggle status">
                                <i data-lucide="${done ? 'rotate-ccw' : 'check'}" class="h-4 w-4"></i>
                            </button>
                            <button type="button" onclick="removeQuickNoteItem('${note.id}')" class="rounded-full p-2 text-slate-400 transition hover:bg-slate-100 hover:text-red-500 dark:hover:bg-slate-800" aria-label="Delete note">
                                <i data-lucide="trash-2" class="h-4 w-4"></i>
                            </button>
                        </div>
                    </div>
                </article>
            `;
        }

        window.submitQuickNote = async function(event) {
            event?.preventDefault();

            const titleInput = document.getElementById('quickNoteTitle');
            const contentInput = document.getElementById('quickNoteContent');
            const dueDateInput = document.getElementById('quickNoteDueDate');
            const pinnedInput = document.getElementById('quickNotePinned');
            const submitButton = document.getElementById('quickNoteSubmitButton');

            const title = titleInput?.value?.trim() || '';
            const content = contentInput?.value?.trim() || '';
            const dueDate = dueDateInput?.value || '';
            const isPinned = !!pinnedInput?.checked;

            if (!title && !content) {
                setQuickNoteFeedback('Isi judul atau catatan dulu biar ada yang disimpan.', 'error');
                return;
            }

            if (submitButton) {
                submitButton.disabled = true;
                submitButton.innerHTML = '<i data-lucide="loader" class="h-4 w-4 animate-spin"></i> Saving...';
                lucide.createIcons();
            }

            try {
                await createQuickNote({
                    authorId: window.currentAuthor,
                    title,
                    content,
                    dueDate: dueDate || null,
                    isPinned,
                    status: 'open'
                });

                if (titleInput) titleInput.value = '';
                if (contentInput) contentInput.value = '';
                if (dueDateInput) dueDateInput.value = '';
                if (pinnedInput) pinnedInput.checked = false;

                setQuickNoteFeedback('Note tersimpan.', 'success');
                await refreshQuickNotes();
            } catch (error) {
                console.error('Failed to create quick note:', error);
                setQuickNoteFeedback('Gagal simpan note. Coba lagi.', 'error');
            } finally {
                if (submitButton) {
                    submitButton.disabled = false;
                    submitButton.innerHTML = '<i data-lucide="notebook-pen" class="h-4 w-4"></i> Save note';
                    lucide.createIcons();
                }
            }
        };

        window.toggleQuickNoteStatus = async function(noteId) {
            const note = quickNotesState.find((item) => item.id === noteId);
            if (!note) return;

            try {
                await updateQuickNote(noteId, {
                    status: note.status === 'done' ? 'open' : 'done'
                });
                await refreshQuickNotes();
            } catch (error) {
                console.error('Failed to update quick note status:', error);
                setQuickNoteFeedback('Gagal update status note.', 'error');
            }
        };

        window.toggleQuickNotePin = async function(noteId) {
            const note = quickNotesState.find((item) => item.id === noteId);
            if (!note) return;

            try {
                await updateQuickNote(noteId, {
                    isPinned: !note.isPinned
                });
                await refreshQuickNotes();
            } catch (error) {
                console.error('Failed to toggle quick note pin:', error);
                setQuickNoteFeedback('Gagal update pin note.', 'error');
            }
        };

        window.removeQuickNoteItem = async function(noteId) {
            if (!confirm('Hapus note ini?')) return;

            try {
                await deleteQuickNote(noteId);
                setQuickNoteFeedback('Note dihapus.', 'success');
                await refreshQuickNotes();
            } catch (error) {
                console.error('Failed to delete quick note:', error);
                setQuickNoteFeedback('Gagal hapus note.', 'error');
            }
        };

        function setQuickNoteFeedback(message, type = 'success') {
            const feedback = document.getElementById('quickNoteFeedback');
            if (!feedback) return;

            feedback.textContent = message;
            feedback.classList.remove('hidden', 'text-emerald-500', 'text-red-500');
            feedback.classList.add(type === 'success' ? 'text-emerald-500' : 'text-red-500');

            window.clearTimeout(window.quickNoteFeedbackTimer);
            window.quickNoteFeedbackTimer = window.setTimeout(() => {
                feedback.classList.add('hidden');
            }, 2200);
        }

        function formatQuickNoteDueDate(value) {
            if (!value) return 'No deadline';
            const date = new Date(value);
            if (Number.isNaN(date.getTime())) return 'No deadline';
            return `Due ${date.toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' })}`;
        }

        function formatQuickNoteTime(value) {
            if (!value) return 'Just now';
            const date = new Date(value);
            if (Number.isNaN(date.getTime())) return 'Just now';
            return `Updated ${formatRelativeTime(date)}`;
        }

        function escapeHtml(value) {
            return String(value)
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;')
                .replace(/'/g, '&#39;');
        }

        window.toggleTheme = function() {
            if (document.documentElement.classList.contains('dark')) {
                document.documentElement.classList.remove('dark');
                localStorage.theme = 'light';
            } else {
                document.documentElement.classList.add('dark');
                localStorage.theme = 'dark';
            }
        };
    </script>

    <script is:inline src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    <script is:inline>
        AOS.init({ once: true, offset: 50, duration: 800 });
        if (window.lucide) { lucide.createIcons(); }
    </script>
</body>
</html>
